//
// wf-amplicon-mgi: MGI long-read haploid amplicon de novo consensus
//
// Configuration for Nextflow DSL2 workflow.
// See https://nextflow.io/docs/latest/config.html for guidance.
//

params {
    // --- I/O ---
    fastq              = null
    out_dir            = "output"
    sample             = null      // override sample name (single-sample runs)

    // --- Read filtering ---
    min_read_length    = 200       // minimum read length (bp); set null to skip
    max_read_length    = null      // maximum read length (bp); set null to skip
    min_read_qual      = null      // minimum mean base quality; set null to skip
    min_n_reads        = 20        // minimum reads per sample after filtering

    // --- Read subsampling ---
    // Drop the longest `drop_frac_longest_reads` fraction of reads before selecting;
    // this removes potential concatemers and anomalous outliers.
    reads_downsampling_size     = 1500
    drop_frac_longest_reads     = 0.0   // 0.0 = disabled; 0.05 = drop top 5%
    take_longest_remaining_reads = true  // take longest of remaining after drop

    // --- Assembly ---
    // minimap2 preset for all-vs-all overlap (miniasm) and draft alignment (racon).
    // Options: ava-pb (PacBio CLR), ava-ont (ONT), ava-hifi (PacBio HiFi).
    // Set to match your MGI long-read data characteristics.
    overlap_preset              = "ava-pb"

    // minimap2 preset for re-alignment of reads to consensus.
    // Options: map-pb (PacBio CLR), map-ont (ONT), map-hifi (PacBio HiFi).
    minimap2_preset             = "map-pb"

    // Contigs shorter than this after miniasm are considered failed (fall back to SPOA)
    force_spoa_length_threshold = 2000

    // --- SPOA ---
    spoa_minimum_relative_coverage = 0.15
    spoa_max_allowed_read_length   = 5000

    // --- QC thresholds ---
    minimum_mean_depth           = 30   // discard consensus if mean depth < this
    primary_alignments_threshold = 0.7  // discard if fraction of primary alns < this
    number_depth_windows         = 100  // windowed depth resolution for QC output

    // --- Resources ---
    threads = 4

    // --- Misc ---
    help             = false
    version          = false
    validate_params  = true
    monochrome_logs  = false
    show_hidden_params = false
    schema_ignore_params = 'show_hidden_params,validate_params,monochrome_logs'
}


manifest {
    name            = 'd-jch/wf-amplicon-mgi'
    author          = 'd-jch'
    homePage        = 'https://github.com/d-jch/wf-amplicon-mgi'
    description     = 'MGI long-read haploid amplicon de novo consensus workflow'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.2'
    version         = '0.1.0'
}


process {
    withLabel:wfamplicon {
        // Use a container image that ships: minimap2, miniasm, racon, samtools,
        // mosdepth, seqkit, bamstats, bgzip, pysam, pandas, spoa Python bindings.
        // Adjust this to point at your preferred image.
        container = "ontresearch/wf-amplicon:sha0ba67476938520e6f132759780d0a0e902925c59"
    }
    shell = ['/bin/bash', '-euo', 'pipefail']
}


profiles {
    standard {
        docker {
            enabled    = true
            runOptions = "--user \$(id -u):\$(id -g) --group-add 100"
        }
    }

    singularity {
        singularity {
            enabled    = true
            autoMounts = true
        }
    }

    conda {
        conda.enabled = true
    }

    local {
        process.executor = 'local'
    }
}


timeline {
    enabled   = true
    overwrite  = true
    file      = "${params.out_dir}/execution/timeline.html"
}
report {
    enabled   = true
    overwrite  = true
    file      = "${params.out_dir}/execution/report.html"
}
trace {
    enabled   = true
    overwrite  = true
    file      = "${params.out_dir}/execution/trace.txt"
}

env {
    PYTHONNOUSERSITE = 1
    JAVA_TOOL_OPTIONS = "-Xlog:disable -Xlog:all=warning:stderr"
}
